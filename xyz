<!-- ===================== style.css ===================== -->
:root {
  --primary: #6a11cb;
  --secondary: #2575fc;
  --bg: linear-gradient(135deg, #667eea, #764ba2);
  --card-bg: rgba(255, 255, 255, 0.15);
  --text: #ffffff;
}

body {
  font-family: 'Segoe UI', sans-serif;
  margin: 0;
  background: var(--bg);
  color: var(--text);
}

header {
  background: rgba(0,0,0,0.6);
  backdrop-filter: blur(10px);
  color: white;
  padding: 15px;
  text-align: center;
  position: sticky;
  top: 0;
}

nav a {
  margin: 10px;
  color: white;
  text-decoration: none;
  font-weight: bold;
  transition: 0.3s;
}

nav a:hover {
  color: #ffd369;
}

.home {
  text-align: center;
  padding: 60px;
}

.home img {
  width: 160px;
  border-radius: 50%;
  border: 4px solid white;
  box-shadow: 0 0 20px rgba(255,255,255,0.6);
}

.projects {
  display: flex;
  gap: 20px;
  padding: 20px;
  flex-wrap: wrap;
}

.card {
  background: var(--card-bg);
  backdrop-filter: blur(12px);
  padding: 15px;
  border-radius: 15px;
  width: 250px;
  box-shadow: 0 8px 32px rgba(0,0,0,0.3);
  transition: transform 0.3s, box-shadow 0.3s;
}

.card:hover {
  transform: translateY(-10px) scale(1.03);
  box-shadow: 0 15px 40px rgba(0,0,0,0.5);
}

.gallery {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
}

.gallery img {
  width: 220px;
  margin: 10px;
  border-radius: 10px;
  transition: 0.3s;
}

.gallery img:hover {
  transform: scale(1.1);
}

button {
  background: linear-gradient(45deg, #ff6a00, #ee0979);
  border: none;
  padding: 10px 15px;
  color: white;
  border-radius: 8px;
  cursor: pointer;
  transition: 0.3s;
}

button:hover {
  opacity: 0.8;
}

.dark-mode {
  --bg: linear-gradient(135deg, #141e30, #243b55);
  --text: #e0e0e0;
  --card-bg: rgba(255,255,255,0.08);
}

function toggleDarkMode() {
  document.body.classList.toggle("dark-mode");
}
